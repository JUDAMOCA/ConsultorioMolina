# Copy to .env.local and fill in real values.

# Supabase — project URL + keys (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public site URL used for QR codes and Wompi redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Wompi payment gateway (all server-side — never exposed to the browser)
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_PRIVATE_KEY=prv_test_xxx
WOMPI_INTEGRITY_KEY=test_integrity_xxx
# Events/webhook secret (Wompi dashboard → Eventos) — verifies webhook signatures
WOMPI_EVENTS_KEY=test_events_xxx

# Resend email notifications (resend.com → API Keys)
RESEND_API_KEY=re_xxx
# Admin inbox that receives new-appointment and payment-confirmed emails
ADMIN_EMAIL=admin@yourclinic.com
# Verified sender address (Resend dashboard → Domains). Falls back to onboarding@resend.dev for testing.
RESEND_FROM_EMAIL=Consultorio Molina <noreply@yourclinic.com>
